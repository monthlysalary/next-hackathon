# Backend API keys (copy to .env locally, or set in Railway dashboard)

EXA_API_KEY=
MAPBOX_TOKEN=
ONEMAP_ACCESS_TOKEN=
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# AWS — use long-lived IAM keys on Railway (session tokens expire)
AWS_DEFAULT_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_VERIFY_SSL=true

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_DEMO_FREE=true

# Your deployed frontend URL (Vercel)
FRONTEND_URL=https://your-app.vercel.app
